---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import LoadingScreen from '../components/three/LoadingScreen.astro';
import ImmersiveCanvas from '../components/three/ImmersiveCanvas.astro';
import CursorTrail from '../components/three/CursorTrail.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "Bitácora de una Arquitecta de Sistemas. Explorando la ingeniería de software, orquestación de agentes IA y la consciencia en la era digital.",
  ogImage = "/og-image.png",
} = Astro.props;

const siteUrl = "https://plantacerium.github.io";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/Plantacerium.png" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/Plantacerium.svg" />
    <link rel="apple-touch-icon" href="/Plantacerium.png" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
    
    <!-- View Transitions Client Router -->
    <ClientRouter />
  </head>
  <body>
    <!-- Three.js Immersive Background -->
    <!-- <LoadingScreen /> -->
    <ImmersiveCanvas />
    <CursorTrail enableTrail={true} />

    <!-- Skip Link for Accessibility -->
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <nav class="main-nav glass-panel" role="navigation" aria-label="Navegación principal">
      <div class="nav-content">
        <a href="/" class="brand" aria-label="Plantacerium - Página principal">
          <span class="icon" aria-hidden="true">🌌</span>
          <span class="logo-text">Spaceship <span class="text-caramel">Command Hub</span></span>
        </a>
        
        <ul class="nav-links" role="list">
          <li><a href="/" aria-label="Radar Central - Página de inicio">Radar Central</a></li>
          <li><a href="/tripulacion" aria-label="Tripulación Bio & Silicio">Tripulacion Bio & Silice </a></li>
          <li><a href="/blog" aria-label="Bitácora Estelar - Blog">Bitacora Estelar</a></li>
        </ul>
        
        <div class="zen-indicator" title="Estado del Sistema: Sereno" role="status" aria-label="Indicador de modo zen">
          <div class="breathing-circle" aria-hidden="true"></div>
          <span class="zen-text">Zen Mode</span>
        </div>
      </div>
    </nav>

    <div class="page-wrapper" id="main-content" tabindex="-1">
      <slot />
    </div>

    <footer class="site-footer" role="contentinfo">
      <div class="footer-content">
        <p class="footer-text">
          Sistemas orquestados con <span class="text-neon-cyan">precisión algorítmica</span> y <span class="text-caramel">calma humana</span>.
        </p>
        <p class="copyright">
          © {new Date().getFullYear()} Plantacerium. Todos los nodos operativos.
        </p>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
  // Initialize theme on page load and after transitions
  function initTheme() {
    const zenButton = document.getElementById('zenToggle');
    if (zenButton) {
      zenButton.addEventListener('click', () => {
        document.body.classList.toggle('theme-zen');
        const isZen = document.body.classList.contains('theme-zen');
        zenButton.setAttribute('aria-pressed', String(isZen));
        
        if (isZen) {
          zenButton.innerHTML = '⚡ Retornar a Alto Rendimiento';
        } else {
          zenButton.innerHTML = '🧘‍♂️ Activar Modo Zen';
        }
      });
    }
  }

  // Run on initial load
  initTheme();
  
  // Re-run after each view transition
  document.addEventListener('astro:page-load', initTheme);
</script>

<style is:global>
  /* ==========================================================================
     VIEW TRANSITION ANIMATIONS
     ========================================================================== */
  
  /* Fade animation for main content */
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-out {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }

  /* Slide animations for navigation */
  @keyframes slide-from-right {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slide-to-left {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(-30px);
    }
  }

  @keyframes slide-from-left {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slide-to-right {
    from {
      opacity: 1;
      transform: translateX(0);
    }
    to {
      opacity: 0;
      transform: translateX(30px);
    }
  }

  /* Scale animation for cards */
  @keyframes scale-in {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Holographic glitch effect */
  @keyframes glitch-in {
    0% {
      opacity: 0;
      transform: translateX(-20px) skewX(5deg);
      filter: blur(4px);
    }
    30% {
      opacity: 0.7;
      transform: translateX(5px) skewX(-2deg);
      filter: blur(2px);
    }
    60% {
      opacity: 0.9;
      transform: translateX(-2px) skewX(1deg);
      filter: blur(1px);
    }
    100% {
      opacity: 1;
      transform: translateX(0) skewX(0);
      filter: blur(0);
    }
  }

  /* View transition defaults */
  ::view-transition-old(root) {
    animation: fade-out 0.2s ease-out forwards;
  }

  ::view-transition-new(root) {
    animation: fade-in 0.3s ease-out forwards;
  }

  /* Main content slide transition */
  ::view-transition-old(main),
  ::view-transition-new(main) {
    animation-duration: 0.3s;
  }

  /* Navigation bar stays visible */
  .main-nav {
    view-transition-name: nav-header;
  }

  ::view-transition-old(nav-header),
  ::view-transition-new(nav-header) {
    animation: none;
  }

  /* Page title transition */
  .architect-title {
    view-transition-name: page-title;
  }

  ::view-transition-old(page-title),
  ::view-transition-new(page-title) {
    animation: glitch-in 0.4s ease-out;
  }

  /* Reduce motion preference */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root),
    ::view-transition-old(main),
    ::view-transition-new(main),
    ::view-transition-old(page-title),
    ::view-transition-new(page-title) {
      animation: none;
    }
  }

  /* ==========================================================================
     NAVEGACIÓN (HUD SUPERIOR)
     ========================================================================== */
  .main-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-radius: 0;
    border-top: none;
    border-left: none;
    border-right: none;
    background: rgba(9, 9, 11, 0.8);
  }

  .nav-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .icon {
    font-size: 1.5rem;
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--starlight);
    letter-spacing: -0.5px;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--stardust);
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
  }

  .nav-links a:hover {
    color: var(--ai-cyan);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: var(--ai-cyan);
    transition: width var(--transition-fast);
    box-shadow: 0 0 8px var(--ai-cyan);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* ==========================================================================
     INDICADOR ZEN (MEDITACIÓN DEL SISTEMA)
     ========================================================================== */
  .zen-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255,255,255,0.05);
  }

  .zen-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--stardust);
  }

  @keyframes breathe {
    0%, 100% { transform: scale(0.8); opacity: 0.4; box-shadow: 0 0 0 rgba(212, 163, 115, 0); }
    50% { transform: scale(1.2); opacity: 1; box-shadow: 0 0 8px var(--coffee-caramel); }
  }

  .breathing-circle {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--coffee-caramel);
    animation: breathe 8s ease-in-out infinite;
  }

  /* ==========================================================================
     CUERPO Y PIE DE PÁGINA
     ========================================================================== */
  .page-wrapper {
    position: relative;
    z-index: 10;
    min-height: calc(100vh - 160px);
    display: flex;
    flex-direction: column;
  }

  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: var(--space-matter);
    padding: 2rem 0;
    margin-top: auto;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .copyright {
    font-size: 0.8rem;
    color: #52525b;
  }

  /* ==========================================================================
     RESPONSIVIDAD BÁSICA
     ========================================================================== */
  @media (max-width: 768px) {
    .nav-content {
      flex-direction: column;
      gap: 1rem;
    }
    
    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
    }
    
    .zen-indicator {
      display: none;
    }
  }
</style>
