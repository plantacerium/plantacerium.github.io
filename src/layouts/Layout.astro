---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Bitácora de una Arquitecta de Sistemas. Explorando la ingeniería de software, orquestación de agentes IA y la consciencia en la era digital." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />

    <link rel="icon" type="image" href="/Plantacerium.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="apple-touch-icon" href="/Plantacerium.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body>
    <nav class="main-nav glass-panel">
      <div class="nav-content">
        <a href="/" class="brand">
          <span class="icon">🌌</span>
          <span class="logo-text">Spaceship <span class="text-caramel">Command Hub</span></span>
        </a>
        
        <ul class="nav-links">
          <li><a href="/">Radar Central</a></li>
          <li><a href="/tripulacion">Tripulacion Bio & Silice </a></li>
          <li><a href="/blog">Bitacora Estelar</a></li>
        </ul>
        
        <div class="zen-indicator" title="Estado del Sistema: Sereno">
          <div class="breathing-circle"></div>
          <span class="zen-text">Zen Mode</span>
        </div>
      </div>
    </nav>

    <div class="page-wrapper">
      <slot />
    </div>

    <footer class="site-footer">
      <div class="footer-content">
        <p class="footer-text">
          Sistemas orquestados con <span class="text-neon-cyan">precisión algorítmica</span> y <span class="text-caramel">calma humana</span>.
        </p>
        <p class="copyright">
          © {new Date().getFullYear()} Plantacerium. Todos los nodos operativos.
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  /* ==========================================================================
     NAVEGACIÓN (HUD SUPERIOR)
     ========================================================================== */
  .main-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-radius: 0;
    border-top: none;
    border-left: none;
    border-right: none;
    background: rgba(9, 9, 11, 0.8); /* Ligeramente más oscuro para la cabecera */
  }

  .nav-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .icon {
    font-size: 1.5rem;
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--starlight);
    letter-spacing: -0.5px;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--stardust);
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
  }

  .nav-links a:hover {
    color: var(--ai-cyan);
  }

  /* Animación de subrayado en hover */
  .nav-links a::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -4px;
    left: 0;
    background-color: var(--ai-cyan);
    transition: width var(--transition-fast);
    box-shadow: 0 0 8px var(--ai-glow-cyan);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* ==========================================================================
     INDICADOR ZEN (MEDITACIÓN DEL SISTEMA)
     ========================================================================== */
  .zen-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255,255,255,0.05);
  }

  .zen-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--stardust);
  }

  /* Animación de respiración profunda (4 segundos inhalar, 4 exhalar) */
  @keyframes breathe {
    0%, 100% { transform: scale(0.8); opacity: 0.4; box-shadow: 0 0 0 rgba(212, 163, 115, 0); }
    50% { transform: scale(1.2); opacity: 1; box-shadow: 0 0 8px var(--coffee-caramel); }
  }

  .breathing-circle {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--coffee-caramel);
    animation: breathe 8s ease-in-out infinite;
  }

  /* ==========================================================================
     CUERPO Y PIE DE PÁGINA
     ========================================================================== */
  .page-wrapper {
    min-height: calc(100vh - 160px); /* Altura total menos nav y footer */
    display: flex;
    flex-direction: column;
  }

  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: var(--space-matter);
    padding: 2rem 0;
    margin-top: auto;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    padding: 0 2rem;
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .copyright {
    font-size: 0.8rem;
    color: #52525b; /* Gris oscuro para no distraer */
  }

  /* Responsividad básica para pantallas pequeñas */
  @media (max-width: 768px) {
    .nav-content {
      flex-direction: column;
      gap: 1rem;
    }
    
    .nav-links {
      flex-wrap: wrap;
      justify-content: center;
    }
    
    .zen-indicator {
      display: none; /* Ocultamos el indicador zen en móviles para ahorrar espacio */
    }
  }
</style>
