---
interface Props {
  enableParticles?: boolean;
  enableGeometry?: boolean;
  enableNebula?: boolean;
  enableGrid?: boolean;
  enableRings?: boolean;
}

const {
  enableParticles = true,
  enableGeometry = true,
  enableNebula = true,
  enableGrid = true,
  enableRings = true
} = Astro.props;
---

<div id="immersive-canvas-container" class="immersive-canvas-container">
  <canvas id="immersive-canvas"></canvas>
  <div class="canvas-overlay"></div>
</div>

<script>
  import * as THREE from 'three';
  import { detectWebGL, getParticleCount, getGeometryComplexity } from '../../utils/webgl';
  import { createParticleSystem, updateParticles, createNebula, updateNebula } from '../../lib/three/particles';
  import { createFloatingGeometries, updateFloatingGeometries, createHolographicGrid, updateGrid, createEnergyRings, updateEnergyRings } from '../../lib/three/geometry';

  class ImmersiveScene {
    private container: HTMLElement;
    private canvas: HTMLCanvasElement;
    private scene: THREE.Scene;
    private camera: THREE.PerspectiveCamera;
    private renderer: THREE.WebGLRenderer;
    private clock: THREE.Clock;
    
    private particles: THREE.Points | null = null;
    private nebula: THREE.Points | null = null;
    private floatingGeometries: any[] = [];
    private grid: THREE.GridHelper | null = null;
    private energyRings: THREE.Mesh[] = [];
    
    private mouseX: number = 0;
    private mouseY: number = 0;
    private targetMouseX: number = 0;
    private targetMouseY: number = 0;
    
    private animationFrameId: number | null = null;
    private isRunning: boolean = false;
    private capabilities: ReturnType<typeof detectWebGL>;

    constructor() {
      this.container = document.getElementById('immersive-canvas-container')!;
      this.canvas = document.getElementById('immersive-canvas') as HTMLCanvasElement;
      this.capabilities = detectWebGL();
      
      this.scene = new THREE.Scene();
      this.clock = new THREE.Clock();
      
      this.camera = new THREE.PerspectiveCamera(
        75,
        window.innerWidth / window.innerHeight,
        0.1,
        1000
      );
      this.camera.position.z = 30;
      
      this.renderer = new THREE.WebGLRenderer({
        canvas: this.canvas,
        antialias: true,
        alpha: true,
        powerPreference: this.capabilities.performanceLevel === 'high' ? 'high-performance' : 'default'
      });
      this.renderer.setSize(window.innerWidth, window.innerHeight);
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      this.renderer.setClearColor(0x000000, 0);
      
      this.init();
      this.bindEvents();
    }

    private init() {
      const particleCount = getParticleCount(this.capabilities);
      const geometryComplexity = getGeometryComplexity(this.capabilities);

      (window as any).loadingScreen?.setProgress(20);

      if (this.capabilities.supported && !this.capabilities.prefersReducedMotion) {
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.3);
        this.scene.add(ambientLight);
        
        const pointLight1 = new THREE.PointLight(0x00f2ff, 1, 100);
        pointLight1.position.set(10, 10, 10);
        this.scene.add(pointLight1);
        
        const pointLight2 = new THREE.PointLight(0x8b5cf6, 0.8, 100);
        pointLight2.position.set(-10, -10, 10);
        this.scene.add(pointLight2);

        (window as any).loadingScreen?.setProgress(40);

        if (this.container.dataset.enableParticles !== 'false') {
          this.particles = createParticleSystem(this.scene, {
            count: particleCount,
            color: '#00f2ff',
            size: 2.5,
            spread: 50
          });
        }

        (window as any).loadingScreen?.setProgress(60);

        if (this.container.dataset.enableNebula !== 'false') {
          this.nebula = createNebula(this.scene);
        }

        if (this.container.dataset.enableGeometry !== 'false') {
          this.floatingGeometries = createFloatingGeometries(this.scene, geometryComplexity);
        }

        if (this.container.dataset.enableGrid !== 'false') {
          this.grid = createHolographicGrid(this.scene);
        }

        if (this.container.dataset.enableRings !== 'false') {
          this.energyRings = createEnergyRings(this.scene);
        }

        (window as any).loadingScreen?.setProgress(80);
      }

      this.scene.fog = new THREE.FogExp2(0x050507, 0.015);
      
      (window as any).loadingScreen?.setProgress(100);
      (window as any).loadingScreen?.complete();
    }

    private bindEvents() {
      window.addEventListener('resize', this.onResize.bind(this));
      window.addEventListener('mousemove', this.onMouseMove.bind(this));
      window.addEventListener('touchmove', this.onTouchMove.bind(this), { passive: true });
      
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          this.pause();
        } else {
          this.resume();
        }
      });

      const intersectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.resume();
            } else {
              this.pause();
            }
          });
        },
        { threshold: 0 }
      );
      intersectionObserver.observe(this.container);
    }

    private onResize() {
      const width = window.innerWidth;
      const height = window.innerHeight;
      
      this.camera.aspect = width / height;
      this.camera.updateProjectionMatrix();
      this.renderer.setSize(width, height);
    }

    private onMouseMove(event: MouseEvent) {
      this.targetMouseX = (event.clientX / window.innerWidth) * 2 - 1;
      this.targetMouseY = -(event.clientY / window.innerHeight) * 2 + 1;
    }

    private onTouchMove(event: TouchEvent) {
      if (event.touches.length > 0) {
        this.targetMouseX = (event.touches[0].clientX / window.innerWidth) * 2 - 1;
        this.targetMouseY = -(event.touches[0].clientY / window.innerHeight) * 2 + 1;
      }
    }

    public start() {
      if (this.isRunning) return;
      this.isRunning = true;
      this.animate();
    }

    public pause() {
      this.isRunning = false;
      if (this.animationFrameId !== null) {
        cancelAnimationFrame(this.animationFrameId);
        this.animationFrameId = null;
      }
    }

    public resume() {
      if (!this.isRunning) {
        this.start();
      }
    }

    public destroy() {
      this.pause();
      window.removeEventListener('resize', this.onResize.bind(this));
      window.removeEventListener('mousemove', this.onMouseMove.bind(this));
      
      this.scene.traverse((object) => {
        if (object instanceof THREE.Mesh) {
          object.geometry.dispose();
          if (Array.isArray(object.material)) {
            object.material.forEach(m => m.dispose());
          } else {
            object.material.dispose();
          }
        }
      });
      
      this.renderer.dispose();
    }

    private animate() {
      if (!this.isRunning) return;
      
      this.animationFrameId = requestAnimationFrame(this.animate.bind(this));
      
      const deltaTime = this.clock.getDelta();
      const time = this.clock.getElapsedTime();
      
      this.mouseX += (this.targetMouseX - this.mouseX) * 0.05;
      this.mouseY += (this.targetMouseY - this.mouseY) * 0.05;
      
      this.camera.position.x = this.mouseX * 3;
      this.camera.position.y = this.mouseY * 2;
      this.camera.lookAt(0, 0, 0);
      
      if (this.particles) {
        updateParticles(this.particles, this.mouseX, this.mouseY, deltaTime);
      }
      
      if (this.nebula) {
        updateNebula(this.nebula, deltaTime);
      }
      
      if (this.floatingGeometries.length > 0) {
        updateFloatingGeometries(this.floatingGeometries, time, this.mouseX, this.mouseY);
      }
      
      if (this.grid) {
        updateGrid(this.grid, time);
      }
      
      if (this.energyRings.length > 0) {
        updateEnergyRings(this.energyRings, time, this.mouseX, this.mouseY);
      }
      
      this.renderer.render(this.scene, this.camera);
    }
  }

  document.addEventListener('astro:page-load', () => {
    const existingScene = (window as any).immersiveScene;
    if (existingScene) {
      existingScene.destroy();
    }
    
    const canvasContainer = document.getElementById('immersive-canvas-container');
    if (canvasContainer) {
      const scene = new ImmersiveScene();
      (window as any).immersiveScene = scene;
      scene.start();
    }
  });
</script>

<style>
  .immersive-canvas-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  #immersive-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .canvas-overlay {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at center, transparent 0%, rgba(5, 5, 7, 0.2) 100%),
      linear-gradient(180deg, rgba(5, 5, 7, 0.3) 0%, transparent 30%, transparent 70%, rgba(5, 5, 7, 0.5) 100%);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .immersive-canvas-container {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .canvas-overlay {
      background: 
        radial-gradient(ellipse at center, transparent 0%, rgba(5, 5, 7, 0.4) 100%),
        linear-gradient(180deg, rgba(5, 5, 7, 0.5) 0%, transparent 40%, transparent 60%, rgba(5, 5, 7, 0.6) 100%);
    }
  }
</style>
