---
interface Props {
  enableTrail?: boolean;
  trailColor?: string;
  maxParticles?: number;
}

const {
  enableTrail = true,
  trailColor = '#00f2ff',
  maxParticles = 20
} = Astro.props;
---

{enableTrail && (
  <div id="cursor-trail-container" class="cursor-trail-container">
    <canvas id="cursor-trail-canvas"></canvas>
  </div>
)}

<script>
  import { initCursorTrail } from '../../lib/cursor-trail';
  initCursorTrail('cursor-trail-canvas');
</script>

<style>
  .cursor-trail-container {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  #cursor-trail-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-trail-container {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .cursor-trail-container {
      display: none;
    }
  }
</style>
