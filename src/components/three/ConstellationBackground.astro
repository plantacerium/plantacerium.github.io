---
interface Props {
  nodeCount?: number;
  connectionDistance?: number;
}

const {
  nodeCount = 25,
  connectionDistance = 150
} = Astro.props;
---

<div 
  class="constellation-container" 
  id="constellation-bg"
  data-node-count={nodeCount}
  data-connection-distance={connectionDistance}
>
  <svg class="constellation-svg" id="constellation-svg">
    <defs>
      <filter id="glow-cyan" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
        <feMerge>
          <feMergeNode in="coloredBlur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <filter id="glow-purple" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
        <feMerge>
          <feMergeNode in="coloredBlur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
      <filter id="glow-gold" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="2.5" result="coloredBlur"/>
        <feMerge>
          <feMergeNode in="coloredBlur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>
    <g id="connections" class="constellation-lines"></g>
    <g id="nodes" class="constellation-nodes"></g>
  </svg>
  <div class="constellation-overlay"></div>
</div>

<script>
  interface Node {
    id: number;
    x: number;
    y: number;
    size: number;
    color: string;
    glow: string;
    opacity: number;
  }

  class ConstellationGenerator {
    private container: HTMLElement;
    private svg: SVGSVGElement;
    private nodesGroup: SVGGElement;
    private connectionsGroup: SVGGElement;
    private nodes: Node[] = [];
    private nodeCount: number;
    private connectionDistance: number;
    private animationFrame: number | null = null;

    constructor() {
      this.container = document.getElementById('constellation-bg')!;
      this.svg = document.getElementById('constellation-svg') as unknown as SVGSVGElement;
      this.nodesGroup = document.getElementById('nodes') as unknown as SVGGElement;
      this.connectionsGroup = document.getElementById('connections') as unknown as SVGGElement;
      this.nodeCount = parseInt(this.container.dataset.nodeCount || '25');
      this.connectionDistance = parseInt(this.container.dataset.connectionDistance || '150');

      if (window.matchMedia('(min-width: 769px)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      this.init();
      this.bindEvents();
    }

    private init() {
      this.generateNodes();
      this.renderNodes();
      this.renderConnections();
      this.startPulseAnimation();
    }

    private generateNodes() {
      const colors = [
        { color: '#00f2ff', glow: 'url(#glow-cyan)' },
        { color: '#8b5cf6', glow: 'url(#glow-purple)' },
        { color: '#d4af37', glow: 'url(#glow-gold)' },
        { color: 'rgba(0, 242, 255, 0.5)', glow: 'url(#glow-cyan)' },
        { color: 'rgba(139, 92, 246, 0.5)', glow: 'url(#glow-purple)' }
      ];

      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const padding = 50;

      for (let i = 0; i < this.nodeCount; i++) {
        const colorSet = colors[Math.floor(Math.random() * colors.length)];
        this.nodes.push({
          id: i,
          x: padding + Math.random() * (vw - padding * 2),
          y: padding + Math.random() * (vh - padding * 2),
          size: 2 + Math.random() * 4,
          color: colorSet.color,
          glow: colorSet.glow,
          opacity: 0.3 + Math.random() * 0.5
        });
      }
    }

    private renderNodes() {
      this.nodes.forEach(node => {
        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('cx', String(node.x));
        circle.setAttribute('cy', String(node.y));
        circle.setAttribute('r', String(node.size));
        circle.setAttribute('fill', node.color);
        circle.setAttribute('opacity', String(node.opacity));
        circle.setAttribute('filter', node.glow);
        circle.setAttribute('class', 'constellation-node');
        circle.dataset.nodeId = String(node.id);
        this.nodesGroup.appendChild(circle);
      });
    }

    private renderConnections() {
      this.connectionsGroup.innerHTML = '';

      for (let i = 0; i < this.nodes.length; i++) {
        for (let j = i + 1; j < this.nodes.length; j++) {
          const nodeA = this.nodes[i];
          const nodeB = this.nodes[j];
          const distance = Math.sqrt(
            Math.pow(nodeB.x - nodeA.x, 2) + Math.pow(nodeB.y - nodeA.y, 2)
          );

          if (distance < this.connectionDistance) {
            const opacity = 1 - (distance / this.connectionDistance);
            const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            line.setAttribute('x1', String(nodeA.x));
            line.setAttribute('y1', String(nodeA.y));
            line.setAttribute('x2', String(nodeB.x));
            line.setAttribute('y2', String(nodeB.y));
            line.setAttribute('stroke', nodeA.color);
            line.setAttribute('stroke-width', '0.5');
            line.setAttribute('opacity', String(opacity * 0.3));
            line.setAttribute('class', 'constellation-line');
            this.connectionsGroup.appendChild(line);
          }
        }
      }
    }

    private startPulseAnimation() {
      let time = 0;
      const animate = () => {
        time += 0.01;
        const circles = this.nodesGroup.querySelectorAll('.constellation-node');
        
        circles.forEach((circle, i) => {
          const node = this.nodes[i];
          const pulse = Math.sin(time + i * 0.5) * 0.2 + 0.8;
          (circle as SVGCircleElement).setAttribute('opacity', String(node.opacity * pulse));
        });

        this.animationFrame = requestAnimationFrame(animate);
      };
      animate();
    }

    private bindEvents() {
      window.addEventListener('resize', () => {
        this.nodes = [];
        this.nodesGroup.innerHTML = '';
        this.connectionsGroup.innerHTML = '';
        this.init();
      });
    }

    public destroy() {
      if (this.animationFrame) {
        cancelAnimationFrame(this.animationFrame);
      }
    }
  }

  document.addEventListener('astro:page-load', () => {
    const existing = (window as any).constellationGenerator;
    if (existing) existing.destroy();
    
    (window as any).constellationGenerator = new ConstellationGenerator();
  });

  document.addEventListener('astro:before-swap', () => {
    const existing = (window as any).constellationGenerator;
    if (existing) existing.destroy();
  });
</script>

<style>
  .constellation-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    display: none;
  }

  .constellation-svg {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
  }

  .constellation-line {
    transition: opacity 0.3s ease;
  }

  .constellation-node {
    transition: opacity 0.3s ease;
  }

  .constellation-overlay {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 30% 20%, rgba(0, 242, 255, 0.03) 0%, transparent 40%),
      radial-gradient(ellipse at 70% 80%, rgba(139, 92, 246, 0.03) 0%, transparent 40%),
      linear-gradient(180deg, rgba(5, 5, 7, 0.6) 0%, transparent 20%, transparent 80%, rgba(5, 5, 7, 0.8) 100%);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .constellation-container {
      display: none;
    }
  }
</style>
