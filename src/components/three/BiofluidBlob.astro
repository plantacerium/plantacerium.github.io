---
interface Props {
  class?: string;
  primaryColor?: string;
  secondaryColor?: string;
  tertiaryColor?: string;
  speed?: number;
  size?: 'sm' | 'md' | 'lg' | 'xl';
}

const {
  class: className = '',
  primaryColor = 'rgba(0, 242, 255, 0.15)',
  secondaryColor = 'rgba(139, 92, 246, 0.12)',
  tertiaryColor = 'rgba(212, 175, 55, 0.08)',
  speed = 20,
  size = 'xl'
} = Astro.props;

const sizeMap = {
  sm: '400px',
  md: '600px',
  lg: '800px',
  xl: '1000px'
};
---

<div class:list={['biofluid-blob-container', `blob-${size}`, className]} data-blob-speed={speed}>
  <div class="blob-wrapper">
    <div class="blob blob-1" style={`--blob-primary: ${primaryColor}; --blob-secondary: ${secondaryColor}; --blob-tertiary: ${tertiaryColor};`}></div>
    <div class="blob blob-2" style={`--blob-primary: ${secondaryColor}; --blob-secondary: ${tertiaryColor}; --blob-tertiary: ${primaryColor};`}></div>
    <div class="blob blob-3" style={`--blob-primary: ${tertiaryColor}; --blob-secondary: ${primaryColor}; --blob-tertiary: ${secondaryColor};`}></div>
  </div>
  <div class="blob-glow"></div>
</div>

<style define:vars={{ speed, blobSize: sizeMap[size] }}>
  .biofluid-blob-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .blob-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: var(--blobSize);
    height: var(--blobSize);
  }

  .blob {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 70%;
    height: 70%;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    filter: blur(60px);
    opacity: 0.6;
    mix-blend-mode: screen;
  }

  .blob::before,
  .blob::after {
    content: '';
    position: absolute;
    inset: -20%;
    border-radius: inherit;
    background: inherit;
    filter: blur(40px);
    opacity: 0.5;
  }

  .blob::after {
    inset: -40%;
    opacity: 0.3;
    filter: blur(80px);
  }

  .blob-1 {
    background: radial-gradient(ellipse at center, var(--blob-primary) 0%, transparent 70%);
    animation: morph-1 calc(var(--speed) * 1s) ease-in-out infinite;
  }

  .blob-2 {
    background: radial-gradient(ellipse at center, var(--blob-secondary) 0%, transparent 70%);
    animation: morph-2 calc(var(--speed) * 1.3s) ease-in-out infinite;
    animation-delay: -5s;
  }

  .blob-3 {
    background: radial-gradient(ellipse at center, var(--blob-tertiary) 0%, transparent 70%);
    animation: morph-3 calc(var(--speed) * 1.6s) ease-in-out infinite;
    animation-delay: -10s;
  }

  .blob-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 242, 255, 0.08) 0%,
      transparent 50%
    );
    filter: blur(30px);
    animation: glow-pulse 8s ease-in-out infinite;
  }

  @keyframes morph-1 {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1) rotate(0deg);
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    }
    25% {
      transform: translate(-40%, -60%) scale(1.15) rotate(90deg);
      border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
    }
    50% {
      transform: translate(-60%, -40%) scale(0.9) rotate(180deg);
      border-radius: 50% 60% 30% 60% / 30% 60% 70% 40%;
    }
    75% {
      transform: translate(-45%, -55%) scale(1.1) rotate(270deg);
      border-radius: 40% 60% 50% 40% / 60% 40% 50% 60%;
    }
  }

  @keyframes morph-2 {
    0%, 100% {
      transform: translate(-60%, -40%) scale(0.95) rotate(45deg);
      border-radius: 50% 50% 40% 60% / 40% 60% 50% 50%;
    }
    33% {
      transform: translate(-40%, -60%) scale(1.2) rotate(135deg);
      border-radius: 60% 40% 50% 50% / 50% 50% 40% 60%;
    }
    66% {
      transform: translate(-50%, -50%) scale(0.85) rotate(225deg);
      border-radius: 40% 60% 60% 40% / 60% 40% 60% 40%;
    }
  }

  @keyframes morph-3 {
    0%, 100% {
      transform: translate(-40%, -60%) scale(1.05) rotate(-30deg);
      border-radius: 40% 60% 60% 40% / 60% 40% 60% 40%;
    }
    50% {
      transform: translate(-60%, -40%) scale(0.9) rotate(210deg);
      border-radius: 60% 40% 40% 60% / 40% 60% 60% 40%;
    }
  }

  @keyframes glow-pulse {
    0%, 100% {
      opacity: 0.5;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1.2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob,
    .blob-glow {
      animation: none;
    }

    .blob {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  @media (max-width: 768px) {
    .blob-wrapper {
      width: 150%;
      height: 150%;
    }

    .blob {
      filter: blur(40px);
      opacity: 0.5;
    }
  }
</style>
