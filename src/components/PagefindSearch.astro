---
/**
 * Pagefind Search Component - Immersive Edition
 * Features fuzzy search with reusable utilities
 */
import { portfolioNodes } from '../data/portfolio';
import { getCollection } from 'astro:content';
import type { SearchItem } from '../lib/search';
import '../styles/search-cards.css';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const posts = await getCollection('blog');
const blogData = posts.map((post): SearchItem => ({
  title: post.data.title,
  description: post.data.description,
  url: `/blog/${post.id}`,
  domain: post.data.author,
  category: 'blog'
}));

const allContent: SearchItem[] = [
  ...portfolioNodes.map(item => ({ 
    ...item, 
    type: 'REPO'
  })),
  ...blogData.map(item => ({ 
    ...item, 
    type: 'LOG'
  }))
];

const searchData = JSON.stringify(allContent);
---

<div class={`search-immersive-container ${className || ''}`}>
  <div class="search-3d-wrapper">
    <div class="search-input-container">
      <div class="search-glow-ring"></div>
      <div class="search-inner">
        <span class="search-icon-wrapper">
          <svg class="search-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </span>
        <input
          type="search"
          id="pagefind-search-input"
          class="search-input"
          placeholder="> Neural search across all content..."
          aria-label="Search across all content"
          autocomplete="off"
          spellcheck="false"
        />
        <div class="search-status" id="search-status">
          <span class="status-dot"></span>
        </div>
      </div>
    </div>
    <div id="search-results" class="search-results-panel" role="region" aria-label="Search results"></div>
  </div>
</div>

<script is:inline define:vars={{ searchData }}>
(function() {
  const allContent = JSON.parse(searchData);

  function fuzzyMatch(text, query) {
    if (!text || !query) return 0;
    const t = text.toLowerCase();
    const q = query.toLowerCase();
    
    if (t.includes(q)) return 1;
    
    let score = 0;
    let qIndex = 0;
    let consecutiveBonus = 0;
    
    for (let i = 0; i < t.length && qIndex < q.length; i++) {
      if (t[i] === q[qIndex]) {
        score += 1 + consecutiveBonus;
        consecutiveBonus += 0.5;
        qIndex++;
      } else {
        consecutiveBonus = 0;
      }
    }
    
    if (qIndex === q.length) {
      return score / q.length;
    }
    
    return 0;
  }

  function fuzzySearch(query) {
    const q = query.toLowerCase().trim();
    if (q.length < 2) return [];
    
    const results = allContent.map(item => {
      const titleScore = fuzzyMatch(item.title, q) * 3;
      const domainScore = fuzzyMatch(item.domain || '', q) * 2;
      const categoryScore = fuzzyMatch(item.category || '', q) * 1.5;
      const descScore = fuzzyMatch(item.description || item.impact || '', q) * 1;
      
      const totalScore = titleScore + domainScore + categoryScore + descScore;
      
      return { ...item, score: totalScore };
    });
    
    return results
      .filter(item => item.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 12);
  }

  function getMatchIndices(text, query) {
    if (!text || !query) return [];
    const indices = [];
    const t = text.toLowerCase();
    const q = query.toLowerCase();
    
    let idx = t.indexOf(q);
    while (idx !== -1) {
      indices.push({ start: idx, end: idx + q.length });
      idx = t.indexOf(q, idx + 1);
    }
    
    return indices;
  }

  function highlightMatch(text, query) {
    if (!text || !query) return text;
    
    const indices = getMatchIndices(text, query);
    if (indices.length === 0) return text;
    
    let result = '';
    let lastEnd = 0;
    
    indices.forEach(({ start, end }) => {
      result += escapeHtml(text.slice(lastEnd, start));
      result += `<mark>${escapeHtml(text.slice(start, end))}</mark>`;
      lastEnd = end;
    });
    
    result += escapeHtml(text.slice(lastEnd));
    return result;
  }

  function escapeHtml(text) {
    const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
    return text.replace(/[&<>"']/g, m => map[m]);
  }

  function renderResults(results, query) {
    if (results.length === 0) {
      return `
        <div class="search-empty">
          <span class="empty-icon">🔍</span>
          <p>No results found for "<span class="query-text">${query}</span>"</p>
        </div>
      `;
    }

    let html = `<div class="results-header">
      <span class="results-count">${results.length} result${results.length !== 1 ? 's' : ''}</span>
      <span class="results-source">Neural Matrix</span>
    </div>
    <div class="results-grid">`;

    results.forEach((result, index) => {
      const excerpt = result.description || result.impact || '';
      const isBlog = result.type === 'LOG';
      const icon = isBlog ? '☕' : '📁';
      const auraClass = isBlog ? 'aura-blog' : 'aura-repo';
      
      html += `
        <a href="${result.url}" class="search-result-card ${auraClass}" style="--item-delay: ${index * 50}ms">
          <div class="search-card-link">
            <header class="search-card-header">
              <div class="search-card-badge">
                <span class="search-card-indicator"></span>
                <span>${icon} ${result.domain || (isBlog ? 'Blog' : result.category)}</span>
              </div>
              <span class="search-card-type">${result.type}</span>
            </header>
            <div class="search-card-body">
              <h4 class="search-card-title">${highlightMatch(result.title, query)}</h4>
              ${excerpt ? `<p class="search-card-desc">${highlightMatch(excerpt, query)}</p>` : ''}
            </div>
            <footer class="search-card-footer">
              <div class="search-card-action">
                <span class="search-card-action-icon">⚡</span>
                <span>Explore</span>
              </div>
              <span class="search-card-arrow">→</span>
            </footer>
          </div>
        </a>
      `;
    });

    html += '</div>';

    return html;
  }

  function initSearch() {
    const searchInput = document.getElementById('pagefind-search-input');
    const resultsContainer = document.getElementById('search-results');
    const searchStatus = document.getElementById('search-status');
    
    if (!searchInput || !resultsContainer) return;
    
    if (searchStatus) {
      searchStatus.innerHTML = '<span class="status-dot fuzzy" title="Fuzzy Search Active"></span>';
    }
    
    let debounceTimer = null;
    
    const container = document.querySelector('.search-3d-wrapper');
    searchInput.addEventListener('focus', () => {
      container?.classList.add('focused');
    });
    searchInput.addEventListener('blur', () => {
      setTimeout(() => container?.classList.remove('focused'), 200);
    });
    
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      
      if (debounceTimer) clearTimeout(debounceTimer);
      
      debounceTimer = setTimeout(() => {
        if (query.length < 2) {
          resultsContainer.innerHTML = '';
          resultsContainer.classList.remove('active');
          return;
        }
        
        resultsContainer.classList.add('active');
        resultsContainer.innerHTML = '<div class="search-loading"><span class="loader-ring"></span>Searching...</div>';
        
        const results = fuzzySearch.call(null, query);
        resultsContainer.innerHTML = renderResults(results, query);
        
      }, 100);
    });
    
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.search-immersive-container')) {
        resultsContainer.classList.remove('active');
      }
    });
    
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        resultsContainer.classList.remove('active');
        searchInput.blur();
      }
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
  
  document.addEventListener('astro:page-load', initSearch);
})();
</script>

<style>
  .search-immersive-container {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    perspective: 1000px;
  }

  .search-3d-wrapper {
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .search-3d-wrapper.focused {
    transform: translateZ(20px) scale(1.02);
  }

  .search-input-container {
    position: relative;
    transform-style: preserve-3d;
  }

  .search-glow-ring {
    position: absolute;
    inset: -4px;
    background: linear-gradient(
      135deg,
      rgba(0, 242, 255, 0.3),
      rgba(139, 92, 246, 0.3),
      rgba(212, 175, 55, 0.2)
    );
    border-radius: calc(var(--border-radius-lg) + 4px);
    filter: blur(20px);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
    animation: glow-rotate 8s linear infinite;
  }

  .search-3d-wrapper.focused .search-glow-ring {
    opacity: 1;
  }

  @keyframes glow-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .search-inner {
    position: relative;
    display: flex;
    align-items: center;
    background: linear-gradient(
      135deg,
      rgba(15, 15, 20, 0.9) 0%,
      rgba(20, 20, 30, 0.85) 100%
    );
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--border-radius-lg);
    padding: 0.5rem;
    transition: all 0.3s ease;
    box-shadow: 
      0 10px 40px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .search-3d-wrapper.focused .search-inner {
    border-color: rgba(0, 242, 255, 0.4);
    box-shadow: 
      0 15px 50px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(0, 242, 255, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .search-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .search-icon {
    color: var(--accent-main);
    transition: all 0.3s ease;
    filter: drop-shadow(0 0 8px rgba(0, 242, 255, 0.5));
  }

  .search-3d-wrapper.focused .search-icon {
    transform: scale(1.1);
    filter: drop-shadow(0 0 12px rgba(0, 242, 255, 0.8));
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    padding: 0.75rem;
    letter-spacing: 0.5px;
  }

  .search-input::placeholder {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .search-status {
    padding: 0 0.75rem;
  }

  .status-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    transition: all 0.3s ease;
  }

  .status-dot.fuzzy {
    background: var(--accent-secondary);
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.6);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.7; }
  }

  .search-results-panel {
    position: absolute;
    top: calc(100% + 1rem);
    left: 0;
    right: 0;
    background: linear-gradient(
      145deg,
      rgba(15, 15, 20, 0.98) 0%,
      rgba(25, 25, 35, 0.95) 100%
    );
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--border-radius-lg);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-10px);
    transform-origin: top center;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: 1000;
    box-shadow: 
      0 25px 60px rgba(0, 0, 0, 0.7),
      0 0 40px rgba(0, 242, 255, 0.08);
    isolation: isolate;
  }

  .search-results-panel.active {
    max-height: 550px;
    overflow-y: auto;
    overflow-x: hidden;
    opacity: 1;
    transform: translateY(0);
  }

  .search-results-panel::-webkit-scrollbar {
    width: 6px;
  }

  .search-results-panel::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 3px;
  }

  .search-results-panel::-webkit-scrollbar-thumb {
    background: rgba(0, 242, 255, 0.4);
    border-radius: 3px;
  }

  .search-results-panel::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 242, 255, 0.6);
  }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(0, 0, 0, 0.2);
  }

  .results-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-main);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .results-source {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent-secondary);
    background: rgba(139, 92, 246, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    padding: 1rem;
    align-items: start;
  }

  .search-result-card {
    animation: card-enter 0.4s ease forwards;
    animation-delay: var(--item-delay, 0ms);
    opacity: 0;
    min-height: 180px;
    height: auto;
  }

  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .search-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 3rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .loader-ring {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(0, 242, 255, 0.2);
    border-top-color: var(--accent-main);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .search-empty {
    text-align: center;
    padding: 3rem;
  }

  .empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .search-empty p {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    margin: 0;
  }

  .query-text {
    color: var(--accent-main);
  }

  @media (max-width: 1200px) {
    .results-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 900px) {
    .results-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .search-immersive-container {
      perspective: none;
    }

    .search-3d-wrapper {
      transform: none !important;
    }

    .search-results-panel {
      position: fixed;
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      border-radius: 20px 20px 0 0;
      max-height: 70vh;
      transform: translateY(100%);
      z-index: 9999;
    }

    .search-results-panel.active {
      transform: translateY(0);
    }

    .results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      padding: 1rem;
    }

    .search-result-card {
      min-height: 160px;
    }
  }

  @media (max-width: 540px) {
    .results-grid {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .search-result-card {
      min-height: 140px;
    }

    .search-card-link {
      padding: 1rem;
    }

    .search-card-title {
      font-size: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-glow-ring,
    .status-dot.fuzzy,
    .loader-ring {
      animation: none;
    }
    
    .search-result-card {
      animation: none;
      opacity: 1;
    }
  }
</style>
