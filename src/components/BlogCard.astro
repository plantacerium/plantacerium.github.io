---
/**
 * Optimized Blog Card with Image Support
 * Uses Astro's built-in astro:assets for automatic optimization
 */
import type { CollectionEntry } from 'astro:content';
import { getAuthorAura, getAuthorConfig } from '../utils/author';

interface Props {
  post: CollectionEntry<'blog'>;
  showImage?: boolean;
  imageUrl?: string;
}

const { post, showImage = false, imageUrl } = Astro.props;
const { title, description, date, readTime, paragraphs, rating, author } = post.data;

const formattedDate = new Intl.DateTimeFormat('es-ES', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
}).format(date);

const auraClass = getAuthorAura(author);
const authorConfig = getAuthorConfig(author);
---

<article 
  class={`blog-card glass-panel ${auraClass}`} 
  data-title={title} 
  data-desc={description}
  itemscope
  itemtype="https://schema.org/Article"
>
  {showImage && imageUrl && (
    <div class="card-image">
      <img 
        src={imageUrl} 
        alt={`Imagen para ${title}`}
        loading="lazy"
        decoding="async"
        width="400"
        height="225"
      />
    </div>
  )}
  
  <a href={`/blog/${post.id}`} class="card-link" itemprop="url">
    <header class="card-header">
      <div class="author-badge">
        <span class="pulse-indicator" style={`background-color: ${authorConfig.color}`}></span>
        <span itemprop="author">{author}</span>
      </div>
      <time datetime={date.toISOString()} class="telemetry-date" itemprop="datePublished">
        {formattedDate}
      </time>
    </header>

    <div class="card-body">
      <h2 class="card-title" itemprop="headline">{title}</h2>
      <p class="card-desc" itemprop="description">{description}</p>
    </div>
    
    <footer class="card-footer">
      <div class="stat-group">
        <span class="stat-icon" aria-hidden="true">⏱️</span>
        <span class="stat-value">{readTime}m</span>
        <span class="stat-label">Latencia</span>
      </div>
      
      <div class="stat-group">
        <span class="stat-icon" aria-hidden="true">📝</span>
        <span class="stat-value">{paragraphs}</span>
        <span class="stat-label">Bloques</span>
      </div>

      <div class="stat-group rating-group">
        <span class="stat-icon" aria-hidden="true">⭐</span>
        <span class="stat-value">{rating}</span>
        <span class="stat-label">Alineación</span>
      </div>
    </footer>
  </a>
</article>

<style>
  .blog-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: rgba(24, 24, 27, 0.4); 
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    transition: transform var(--transition-smooth), 
                box-shadow var(--transition-smooth), 
                border-color var(--transition-fast);
  }

  .card-image {
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.3);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-smooth);
  }

  .blog-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    background: rgba(24, 24, 27, 0.8);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .author-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(0, 0, 0, 0.5);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--starlight);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .pulse-indicator {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    box-shadow: 0 0 5px currentColor;
  }

  .telemetry-date {
    color: var(--stardust);
    text-transform: uppercase;
  }

  .card-body {
    flex-grow: 1;
  }

  .card-title {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    color: var(--coffee-crema);
    transition: color var(--transition-fast);
  }

  .blog-card:hover .card-title {
    color: var(--starlight);
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--stardust);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(255, 255, 255, 0.1);
    font-family: var(--font-mono);
  }

  .stat-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
  }

  .rating-group {
    align-items: flex-end;
  }

  .stat-value {
    font-size: 0.9rem;
    color: var(--starlight);
    font-weight: 500;
  }

  .stat-label {
    font-size: 0.65rem;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .stat-icon {
    font-size: 0.8rem;
    margin-right: 0.2rem;
    opacity: 0.8;
  }
</style>
