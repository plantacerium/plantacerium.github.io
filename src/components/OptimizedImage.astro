---
/**
 * Optimized Image Component
 * Uses Astro's built-in astro:assets for automatic optimization
 * Supports lazy loading, responsive images, and format optimization
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  class?: string;
  style?: string;
  format?: 'webp' | 'avif' | 'png' | 'jpg';
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  class: className,
  style,
  format,
} = Astro.props;
---

<figure class:list={['image-wrapper', className]} style={style}>
  <Image
    src={src}
    alt={alt}
    width={width || 800}
    height={height || 450}
    loading={loading}
    decoding="async"
    class="optimized-image"
    format={format}
  />
  <slot name="caption" />
</figure>

<style>
  .image-wrapper {
    margin: 2rem 0;
    border-radius: var(--border-radius-md);
    overflow: hidden;
  }

  .optimized-image {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
