---
/**
 * Search Result Card Component
 * Renders individual search results as immersive 3D cards
 */
interface Props {
  url: string;
  title: string;
  type: 'REPO' | 'LOG';
  icon: string;
  domain?: string;
  query: string;
  delay?: number;
}

const { url, title, type, icon, domain, query, delay = 0 } = Astro.props;

function highlightMatch(text: string, q: string): string {
  if (!q) return text;
  const regex = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
  return text.replace(regex, '<mark>$1</mark>');
}

const highlightedTitle = highlightMatch(title, query);
---

<a href={url} class="result-card" style={`--item-delay: ${delay}ms`}>
  <div class="card-inner">
    <div class="card-header">
      <span class="card-icon">{icon}</span>
      <span class="card-type">{type}</span>
    </div>
    <h4 class="card-title" set:html={highlightedTitle} />
    {domain && <p class="card-domain">{domain}</p>}
    <div class="card-footer">
      <span class="card-action">Explore</span>
      <span class="card-arrow">→</span>
    </div>
  </div>
  <div class="card-glow"></div>
</a>

<style>
  .result-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    perspective: 1000px;
    animation: card-enter 0.4s ease forwards;
    animation-delay: var(--item-delay, 0ms);
    opacity: 0;
  }

  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.25rem;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.04) 0%,
      rgba(255, 255, 255, 0.01) 100%
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--border-radius-md);
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    z-index: 1;
    overflow: hidden;
  }

  .card-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 242, 255, 0.08) 0%,
      transparent 50%,
      rgba(139, 92, 246, 0.05) 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .card-glow {
    position: absolute;
    inset: -2px;
    background: linear-gradient(
      135deg,
      rgba(0, 242, 255, 0.25),
      rgba(139, 92, 246, 0.2)
    );
    border-radius: calc(var(--border-radius-md) + 2px);
    filter: blur(12px);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .result-card:hover .card-inner {
    transform: translateY(-4px) rotateX(2deg);
    border-color: rgba(0, 242, 255, 0.2);
    box-shadow: 
      0 15px 35px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .result-card:hover .card-inner::before {
    opacity: 1;
  }

  .result-card:hover .card-glow {
    opacity: 0.6;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .card-icon {
    font-size: 1.5rem;
    filter: drop-shadow(0 0 8px currentColor);
  }

  .card-type {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--accent-main);
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(0, 242, 255, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(0, 242, 255, 0.2);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    line-height: 1.3;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-title :global(mark) {
    background: rgba(0, 242, 255, 0.25);
    color: var(--accent-main);
    padding: 0 0.15em;
    border-radius: 2px;
  }

  .card-domain {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .card-action {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .card-arrow {
    font-size: 1rem;
    color: var(--text-muted);
    transform: translateX(-5px);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .result-card:hover .card-arrow {
    transform: translateX(0);
    opacity: 1;
    color: var(--accent-main);
  }

  @media (prefers-reduced-motion: reduce) {
    .result-card {
      animation: none;
      opacity: 1;
    }
  }
</style>
