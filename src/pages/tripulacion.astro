---
import Layout from '../layouts/Layout.astro';
import { crew } from '../data/crew';
---

<Layout title="Tripulación | Humano & Máquina">
  <div class="scanline" aria-hidden="true"></div>
  
  <main class="crew-environment" id="main-content">
    <header class="section-header" transition:name="hero-section" transition:animate="fade">
      <h1 class="architect-title">El Colectivo <span class="text-gradient">Neuronal</span></h1>
      <p class="text-secondary">Conoce a la inteligencia biológica y de silicio que orquesta esta nave.</p>
    </header>

    <div class="crew-grid" role="list" aria-label="Tripulación del proyecto" transition:name="crew-section" transition:animate="slide">
      {crew.map((member, index) => (
        <article class={`crew-card glass-panel type-${member.type}`} 
                 role="listitem" 
                 style={`--item-index: ${index}`}
                 transition:name={`crew-${index}`}>
          <div class="card-glow" aria-hidden="true"></div>
          <div class="crew-header">
            <h2 class="crew-name">{member.name}</h2>
            <span class="mono-tag">{member.role}</span>
          </div>
          
          <div class="crew-specs">
            <span class="spec-label">> Hardware/Software:</span>
            <span class="spec-value">{member.specs}</span>
          </div>
          
          <p class="crew-desc">{member.desc}</p>
          
          {member.tools && member.tools.length > 0 && (
            <div class="crew-tools" aria-label="Herramientas específicas">
              <span class="tools-label">Herramientas:</span>
              <div class="tools-list">
                {member.tools.map((tool) => (
                  <span class="tool-tag">{tool}</span>
                ))}
              </div>
            </div>
          )}
        </article>
      ))}
    </div>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    gsap.fromTo(".section-header",
      { y: 30, opacity: 0, filter: "blur(5px)" },
      { y: 0, opacity: 1, filter: "blur(0px)", duration: 0.8, ease: "power2.out" }
    );

    gsap.fromTo(".crew-card",
      { scale: 0.95, opacity: 0, y: 20 },
      { scale: 1, opacity: 1, y: 0, duration: 0.5, stagger: 0.08, delay: 0.3, ease: "back.out(1.2)" }
    );
  });
</script>

<style>
  .crew-environment { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .architect-title { font-size: 3rem; margin-bottom: 1rem; }
  
  .crew-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2rem;
  }

  .crew-card {
    position: relative;
    padding: 2.5rem;
    border: 1px solid var(--panel-border);
    overflow: hidden;
    transition: transform var(--transition-smooth);
  }

  .crew-card:hover { transform: translateY(-5px); }

  .card-glow {
    position: absolute;
    top: -50px; right: -50px;
    width: 150px; height: 150px;
    background: radial-gradient(circle, var(--accent-main) 0%, transparent 70%);
    opacity: 0.1;
    border-radius: 50%;
  }

  .type-human .card-glow { background: radial-gradient(circle, var(--accent-warm) 0%, transparent 70%); }
  .type-llm .card-glow { background: radial-gradient(circle, var(--accent-secondary) 0%, transparent 70%); }

  .crew-header { margin-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 1rem; }
  .crew-name { font-family: var(--font-display); font-size: 1.8rem; margin-bottom: 0.5rem; color: var(--text-primary); }
  
  .crew-specs {
    background: rgba(0,0,0,0.4);
    padding: 1rem;
    border-radius: var(--border-radius-sm);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    border-left: 3px solid var(--accent-main);
  }

  .spec-label { color: var(--text-muted); display: block; margin-bottom: 0.3rem; }
  .spec-value { color: var(--text-primary); }
  .crew-desc { color: var(--text-secondary); line-height: 1.7; }

  .crew-tools {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(255,255,255,0.1);
  }

  .tools-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 0.5rem;
  }

  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tool-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--border-radius-sm);
    color: var(--text-secondary);
  }
</style>
