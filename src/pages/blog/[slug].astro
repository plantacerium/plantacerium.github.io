---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getAuthorClass } from '../../utils/author';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');

  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, description, date, readTime = 5, paragraphs = 10, author, rating } = entry.data;

const formattedDate = new Intl.DateTimeFormat('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const auraClass = getAuthorClass(author);
---

<Layout title={`${title} | Terminal Café`}>

  <div class="reading-progress-bar" id="readingProgress" role="progressbar" aria-label="Progreso de lectura" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>

  <main class="post-environment" id="main-content">

    <nav class="post-navigation" aria-label="Navegación de publicaciones" transition:name="nav-section" transition:animate="fade">
      <a href="/blog" class="btn-return" aria-label="Volver al archivo de blog">
        <span class="icon" aria-hidden="true">←</span> Volver al Archivo
      </a>
    </nav>

    <article class="post-container glass-panel" itemscope itemtype="https://schema.org/Article" transition:name={`card-${entry.id}`} transition:animate="fade">
      <meta itemprop="datePublished" content={date.toISOString()} />
      <meta itemprop="author" content={author} />

      <header class="post-header">
        <div class="telemetry-bar" role="list" aria-label="Metadatos del artículo">
          <div class="telemetry-item" role="listitem">
            <span class="pulse-dot" aria-hidden="true"></span>
            <time datetime={date.toISOString()} itemprop="datePublished">{formattedDate}</time>
          </div>
          <div class="telemetry-item" role="listitem">
            <span class="mono-tag">Latencia: {readTime} min</span>
          </div>
          <div class="telemetry-item" role="listitem">
            <span class="mono-tag">Bloques: {paragraphs}</span>
          </div>
        </div>

        <h1 class="post-title" itemprop="headline" transition:name="page-title">{title}</h1>
        <p class="post-description" itemprop="description">{description}</p>

        <div class="author-signature">
          <span itemprop="author">Orquestado por: <span class={`author-name ${auraClass}`}>{author}</span></span>
          <span class="rating-badge" aria-label={`Calificación: ${rating}`}>Alineación: ⭐ {rating}</span>
        </div>
      </header>

      <div class="separator-line" aria-hidden="true"></div>

      <section class="mdx-content" itemprop="articleBody" transition:name="content-section" transition:animate="slide">
        <Content />
      </section>

      <footer class="post-footer">
        <div class="end-of-transmission">
          <span class="mono-tag">> Fin de la transmisión.</span>
          <a href="#" class="btn-return-top" aria-label="Volver arriba">↑ Ascender</a>
        </div>
      </footer>

    </article>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";

  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const progressBar = document.getElementById('readingProgress');
    if (progressBar) {
      progressBar.style.width = scrolled + '%';
      progressBar.setAttribute('aria-valuenow', String(Math.round(scrolled)));
    }
  });

  document.addEventListener("astro:page-load", () => {
    gsap.fromTo(".post-container",
      { y: 30, opacity: 0, filter: "blur(5px)" },
      { y: 0, opacity: 1, filter: "blur(0px)", duration: 0.6, ease: "power2.out" }
    );

    gsap.fromTo(".mdx-content",
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.5, delay: 0.3, ease: "power2.out" }
    );
  });
</script>

<style>
  .reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-main), var(--accent-secondary));
    width: 0%;
    z-index: 1000;
    transition: width 0.1s ease-out;
    box-shadow: 0 0 10px var(--accent-glow);
  }

  .post-environment {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem 6rem;
  }

  .post-navigation {
    margin-bottom: 2rem;
  }

  .btn-return {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .btn-return:hover {
    color: var(--accent-main);
  }

  .post-container {
    padding: 3rem 4rem;
  }

  .post-header { margin-bottom: 3rem; }

  .telemetry-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    align-items: center;
  }

  .telemetry-item { display: flex; align-items: center; gap: 0.4rem; }
  .pulse-dot {
    width: 6px;
    height: 6px;
    background-color: var(--accent-main);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-glow);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .post-title { font-size: 3rem; line-height: 1.2; margin-bottom: 1rem; color: var(--text-primary); font-family: var(--font-display); }
  .post-description { font-size: 1.25rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 2rem; }

  .author-signature {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--border-radius-sm);
    border-left: 2px solid var(--panel-border);
  }

  .author-name { font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }

  .separator-line {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    margin-bottom: 3rem;
  }

  .mdx-content { font-size: 1.1rem; line-height: 1.8; color: var(--text-secondary); }

  .mdx-content h2, .mdx-content h3, .mdx-content h4 { color: var(--text-primary); margin-top: 3rem; margin-bottom: 1rem; font-family: var(--font-display); }
  .mdx-content h2 { font-size: 2rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; }
  .mdx-content h3 { font-size: 1.5rem; color: var(--accent-warm); }

  .mdx-content p { margin-bottom: 1.5rem; }
  .mdx-content a { color: var(--accent-main); text-decoration: underline; text-decoration-color: rgba(0, 242, 255, 0.3); text-underline-offset: 4px; transition: all var(--transition-fast); }
  .mdx-content a:hover { color: var(--text-primary); text-decoration-color: var(--accent-main); background: rgba(0, 242, 255, 0.1); }

  .mdx-content ul, .mdx-content ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .mdx-content li { margin-bottom: 0.5rem; }
  .mdx-content li::marker { color: var(--accent-secondary); }

  .mdx-content pre {
    background: #09090b !important;
    padding: 1.5rem;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-left: 3px solid var(--accent-main);
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.95rem;
    box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.8);
  }
  .mdx-content code { font-family: var(--font-mono); }
  .mdx-content p code, .mdx-content li code { background: rgba(255, 255, 255, 0.05); padding: 0.2em 0.4em; border-radius: 4px; color: var(--accent-warm); font-size: 0.9em; }

  .mdx-content blockquote {
    margin: 2rem 0;
    padding: 1.5rem;
    background: rgba(212, 163, 115, 0.05);
    border-left: 4px solid var(--accent-warm);
    border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
    font-style: italic;
    color: var(--text-primary);
  }
  .mdx-content blockquote p:last-child { margin-bottom: 0; }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .end-of-transmission { display: flex; justify-content: space-between; align-items: center; }
  .btn-return-top {
    font-family: var(--font-mono); color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; padding: 0.5rem 1rem; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--border-radius-sm); transition: all var(--transition-fast);
  }
  .btn-return-top:hover { color: var(--accent-main); border-color: var(--accent-main); }

  @media (max-width: 768px) {
    .post-container { padding: 2rem 1.5rem; }
    .post-title { font-size: 2.2rem; }
    .author-signature { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
