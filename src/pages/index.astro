  { title: "Storyteller Sound Board", url: "https://github.com/plantacerium/SoundBoardStorytelling", domain: "Deep Space Ambient", impact: "Turn your storytelling sessions into immersive auditory journeys.", category: "ui" },
  { title: "Ripple Oscilloscope", url: "https://github.com/plantacerium/RippleOscilloscope", domain: "Audio Visualizer", impact: "Pushing the boundaries of web graphics by combining Rust, WebGPU and Web.", category: "ui" },
  { title: "Silicio Socratico", url: "https://github.com/plantacerium/SilicioSocratico", domain: "Thinking Code", impact: "Intelligence Configuration, Socratic Agent, Get Domain Knowledge.", category: "system" },
  { title: "Silice Code Base Mapper", url: "https://github.com/plantacerium/SIliceCodeBaseMapper", domain: "Codebase to Knowledge Graph", impact: "Transforms codebases into a Structured Knowledge Graph optimized for LLMs ingestion.", category: "system" },
  { title: "Resonant Planet", url: "https://github.com/plantacerium/ResonantPlanet", domain: "Biósfera sónica interactiva", impact: "Transforma archivos de audio y texto en capas geológicas de un planeta de conciencia.", category: "zen" },
  { title: "Gaia Human Synapse", url: "https://github.com/plantacerium/GaiaHumanSynapse", domain: "Protocolo de CoEvolución", impact: "Nosotros somos la sinapsis que permite al planeta soñar en binario.", category: "zen" }
];

const getCategoryIcon = (category: string) => {
  switch(category) {
    case 'zen': return '🧘‍♂️';
    case 'system': return '⚡';
    case 'ui': return '🌌';
    default: return '⚙️';
  }
};
---

<Layout title="Plantacerium | Architect. Engineer. Strategist.">

  <div class="scanline"></div>

  <main class="command-hub max-width-expanded">

    <header class="hero-section glass-panel gs-reveal">
      <div class="system-status">
        <span class="status-dot active"></span>
        <span class="mono-tag">MINERAL INTELLIGENCE: ONLINE</span>
      </div>

      <h1 class="architect-title">Plantacerium</h1>
      <h2 class="architect-subtitle text-gradient">Architect. Engineer. Strategist.</h2>

      <p class="manifesto">
        I am a Senior Software Engineer who operates where "impossible" meets "deployed."
        My approach is one: <strong>Dream Big, Execute Immediately.</strong>
        I don't wait for the future; I compile it.
      </p>

      <div class="toolchain-tags">
        <span class="badge">AI/LLM</span>
        <span class="badge">RUST</span>
        <span class="badge">PYTHON</span>
        <span class="badge">LINUX/CLI</span>
      </div>

      <div class="action-links">
        <a href="https://github.com/plantacerium" target="_blank" class="btn btn-active">
          ⭐ GitHub Universe
        </a>
        <a href="https://www.youtube.com/@Plantacerium" target="_blank" class="btn">
          ▶ Transmisiones (YouTube)
        </a>
      </div>
    </header>

    <section class="omni-search-container glass-panel gs-reveal">
      <div class="search-terminal">
        <span class="search-icon">⚲</span>
        <input
          type="text"
          id="globalSearch"
          placeholder="> Indexar consciencia: buscar en repositorios y bitácoras..."
          autocomplete="off"
        />
      </div>

      <div class="filter-controls">
        <div class="filter-tags">
          <span class="badge">Repositorios: {portfolioNodes.length}</span>
          <span class="badge">Bitácoras: {posts.length}</span>
        </div>
        <button id="zenToggle" class="btn btn-zen">
          🧘‍♂️ Activar Modo Zen
        </button>
      </div>
    </section>

    <section class="portfolio-matrix">
      <div class="node-grid" id="masterGrid">

        {posts.map((post) => (
          <article class:list={["repository-node", "glass-panel", "type-blog", "gs-node"]}
                   data-title={post.data.title}
                   data-desc={post.data.description}
                   data-type="blog">
            <a href={`/blog/${post.id}`} class="node-link">
              <div class="node-header">
                <span class="node-icon">☕</span>
                <span class="mono-tag domain-tag">LOG | {post.data.author}</span>
              </div>
              <h4 class="node-title text-gradient">{post.data.title}</h4>
              <p class="node-impact">{post.data.description}</p>
              <div class="node-footer">
                <span class="execute-cmd">> read_memory_block()</span>
                <span class="line-decorator"></span>
              </div>
            </a>
          </article>
        ))}

        {portfolioNodes.map((node) => (
          <article class:list={["repository-node", "glass-panel", `type-${node.category}`, "gs-node"]}
                   data-title={node.title}
                   data-desc={node.impact}
                   data-type="repo">
            <a href={node.url} target="_blank" rel="noopener noreferrer" class="node-link">
              <div class="node-header">
                <span class="node-icon">{getCategoryIcon(node.category)}</span>
                <span class="mono-tag domain-tag">REPO | {node.domain}</span>
              </div>
              <h4 class="node-title">{node.title}</h4>
              <p class="node-impact">{node.impact}</p>
              <div class="node-footer">
                <span class="execute-cmd">> git clone protocol</span>
                <span class="line-decorator"></span>
              </div>
            </a>
          </article>
        ))}

      </div>

      <div id="noResults" class="hidden error-msg">
        <p>Error 404: No se detectaron anomalías ni registros con esos parámetros.</p>
      </div>
    </section>

    <footer class="hub-footer glass-panel gs-reveal">
      <h3 class="title-display">🌐 Connect & Scale</h3>
      <p class="text-secondary">Available for high-level architectural consulting and breaking barriers in open source.</p>

      <div class="social-grid">
        <a href="https://ko-fi.com/plantacerium" target="_blank" class="social-link">☕ Support via Ko-Fi</a>
        <a href="https://discord.gg/nbZqzwKXGS" target="_blank" class="social-link">💬 Neural Net (Discord)</a>
        <a href="https://plantacerium.github.io/" target="_blank" class="social-link">📡 Central Command Hub</a>
      </div>

      <div class="signature">
        Made with <span class="heart">♥</span> and brain by <strong>Plantacerium</strong>
      </div>
    </footer>

  </main>
</Layout>

<script>
  import { gsap } from "gsap";

  // LÓGICA DEL BUSCADOR OMNISCIENTE
  const searchInput = document.getElementById('globalSearch') as HTMLInputElement;
  const allNodes = document.querySelectorAll('.gs-node');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    let visibleCount = 0;

    allNodes.forEach(node => {
      const el = node as HTMLElement;
      const title = el.dataset.title?.toLowerCase() || '';
      const desc = el.dataset.desc?.toLowerCase() || '';

      if (title.includes(term) || desc.includes(term)) {
        el.style.display = 'flex';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  });

  // LÓGICA DEL MODO ZEN
  const zenToggle = document.getElementById('zenToggle');
  zenToggle?.addEventListener('click', () => {
    document.body.classList.toggle('theme-zen');
    const isZen = document.body.classList.contains('theme-zen');

    // Cambiamos el texto y la estética del botón
    if (isZen) {
      zenToggle.innerHTML = '⚡ Retornar a Alto Rendimiento';
      gsap.fromTo("body", {opacity: 0.8}, {opacity: 1, duration: 1, ease: "power2.inOut"});
    } else {
      zenToggle.innerHTML = '🧘‍♂️ Activar Modo Zen';
      gsap.fromTo("body", {opacity: 0.8}, {opacity: 1, duration: 0.5});
    }
  });

// ANIMACIONES DE ENTRADA (Boot Sequence)
  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo(".gs-reveal",
      { y: 30, opacity: 0, filter: "blur(5px)" },
      { y: 0, opacity: 1, filter: "blur(0px)", duration: 0.8, stagger: 0.2, ease: "power2.out" }
    );

    const nodesToAnimate = Array.from(document.querySelectorAll('.gs-node')).slice(0, 12);
    // CORRECCIÓN GSAP: Eliminamos el "-=0.4" y usamos delay
    gsap.fromTo(nodesToAnimate,
      { scale: 0.95, opacity: 0, y: 20 },
      { scale: 1, opacity: 1, y: 0, duration: 0.5, stagger: 0.05, delay: 0.4, ease: "back.out(1.2)" }
    );
  });
</script>

<style>
  /* ==========================================================================
     LAYOUT Y ESTRUCTURA GLOBAL
     ========================================================================== */
  .max-width-expanded {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ==========================================================================
     HERO SECTION
     ========================================================================== */
  .hero-section {
    padding: 4rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-top: 1px solid var(--accent-main);
  }

  .architect-title {
    font-size: 4rem;
    letter-spacing: 2px;
    margin: 1rem 0 0.5rem;
    font-family: var(--font-display);
  }

  .architect-subtitle {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    letter-spacing: 4px;
    font-family: var(--font-mono);
  }

  .manifesto {
    max-width: 800px;
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .manifesto strong { color: var(--text-primary); }

  .toolchain-tags {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .action-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ==========================================================================
     BARRA OMNISCIENTE Y CONTROLES
     ========================================================================== */
  .omni-search-container {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .search-terminal {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin-bottom: 1.5rem;
  }

  .search-icon {
    position: absolute;
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: var(--accent-main);
  }

  input[type="text"] {
    width: 100%;
    padding: 1.5rem 1.5rem 1.5rem 4rem;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--panel-border);
    border-radius: var(--border-radius-md);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    outline: none;
    transition: all var(--transition-fast);
  }

  input[type="text"]:focus {
    border-color: var(--accent-main);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .filter-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 900px;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .filter-tags { display: flex; gap: 1rem; }

  .btn-zen {
    background: transparent;
    border-color: var(--accent-warm);
    color: var(--accent-warm);
  }
  .btn-zen:hover {
    background: rgba(212, 163, 115, 0.1);
    box-shadow: 0 0 15px rgba(212, 163, 115, 0.3);
  }

  /* ==========================================================================
     MATRIZ DE NODOS (4 COLUMNAS)
     ========================================================================== */
  .node-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .repository-node {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--panel-border);
    transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
    min-height: 250px;
  }

  .node-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .type-blog:hover { border-color: var(--accent-secondary); box-shadow: 0 10px 30px rgba(139, 92, 246, 0.15); }
  .type-system:hover { border-color: var(--accent-main); box-shadow: 0 10px 30px rgba(0, 242, 255, 0.15); }
  .type-zen:hover { border-color: var(--accent-warm); box-shadow: 0 10px 30px rgba(212, 163, 115, 0.15); }
  .type-ui:hover { border-color: #f472b6; box-shadow: 0 10px 30px rgba(244, 114, 182, 0.15); }

  .repository-node:hover {
    transform: translateY(-4px);
    background: rgba(30, 30, 35, 0.9);
  }

  .node-header { margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .node-title { font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .node-impact { font-size: 0.9rem; color: var(--text-secondary); flex-grow: 1; line-height: 1.5; }
  .node-footer { margin-top: 1.5rem; display: flex; align-items: center; gap: 1rem; opacity: 0.7; }
  .execute-cmd { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent-main); }
  .line-decorator { flex-grow: 1; height: 1px; background: linear-gradient(90deg, var(--accent-main), transparent); }

  .hidden { display: none; }
  .error-msg { text-align: center; padding: 4rem; color: var(--accent-warm); font-family: var(--font-mono); }

  /* ==========================================================================
     FOOTER
     ========================================================================== */
  .hub-footer {
    padding: 3rem;
    text-align: center;
    border-bottom: 1px solid var(--accent-secondary);
  }

  .social-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
    margin: 2rem 0;
  }

  .social-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--border-radius-sm);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    border-color: var(--accent-warm);
    color: var(--accent-warm);
    background: rgba(212, 163, 115, 0.05);
  }

  .signature {
    margin-top: 3rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .heart {
    color: #ef4444;
    animation: heartbeat 1.5s infinite;
    display: inline-block;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    15% { transform: scale(1.3); }
    30% { transform: scale(1); }
    45% { transform: scale(1.3); }
    60% { transform: scale(1); }
  }

  /* ==========================================================================
     MEDIA QUERIES (Responsividad 4 a 1 columnas)
     ========================================================================== */
  @media (max-width: 1400px) { .node-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 1024px) { .node-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .architect-title { font-size: 2.5rem; }
    .filter-controls { flex-direction: column; justify-content: center; }
  }
  @media (max-width: 600px) { .node-grid { grid-template-columns: 1fr; } }
</style>
