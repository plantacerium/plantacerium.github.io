---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { portfolioNodes, getCategoryIcon } from '../data/portfolio';
import PagefindSearch from '../components/PagefindSearch.astro';

const posts = (await getCollection('blog')).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Plantacerium | Architect. Engineer. Strategist.">

  <div class="scanline" aria-hidden="true"></div>

  <main class="command-hub max-width-expanded" id="main-content">

    <header class="hero-section glass-panel gs-reveal" transition:name="hero-section" transition:animate="fade">
      <div class="system-status" role="status" aria-live="polite">
        <span class="status-dot active" aria-hidden="true"></span>
        <span class="mono-tag">MINERAL INTELLIGENCE: ONLINE</span>
      </div>

      <h1 class="architect-title" transition:name="page-title">Plantacerium</h1>
      <h2 class="architect-subtitle text-gradient">Architect. Engineer. Strategist.</h2>

      <p class="manifesto">
        I am a Senior Software Engineer who operates where "impossible" meets "deployed."
        My approach is one: <strong>Dream Big, Execute Immediately.</strong>
        I don't wait for the future; I compile it.
      </p>

      <div class="toolchain-tags" role="list" aria-label="Tecnologías utilizadas">
        <span class="badge" role="listitem">AI/LLM</span>
        <span class="badge" role="listitem">RUST</span>
        <span class="badge" role="listitem">PYTHON</span>
        <span class="badge" role="listitem">LINUX/CLI</span>
      </div>

      <div class="action-links">
        <a href="https://github.com/plantacerium" target="_blank" rel="noopener noreferrer" class="btn btn-active" aria-label="Ver perfil de GitHub">
          ⭐ GitHub Universe
        </a>
        <a href="https://www.youtube.com/@Plantacerium" target="_blank" rel="noopener noreferrer" class="btn" aria-label="Ver canal de YouTube">
          ▶ Transmisiones (YouTube)
        </a>
      </div>
    </header>

    <section class="omni-search-container glass-panel gs-reveal" transition:name="search-section" transition:animate="fade">
      <PagefindSearch />
      
      <div class="filter-controls">
        <div class="filter-tags" role="status" aria-live="polite">
          <span class="badge">Repositorios: {portfolioNodes.length}</span>
          <span class="badge">Bitácoras: {posts.length}</span>
        </div>
        <button id="zenToggle" class="btn btn-zen" type="button" aria-pressed="false">
          🧘‍♂️ Activar Modo Zen
        </button>
      </div>
    </section>

    <section class="portfolio-matrix" aria-label="Proyectos y bitácoras" transition:name="portfolio-section" transition:animate="slide">
      <div class="node-grid" id="masterGrid" role="list">

        {posts.map((post, index) => (
          <article class:list={["repository-node", "glass-panel", "type-blog", "gs-node"]}
                   data-title={post.data.title}
                   data-desc={post.data.description}
                   data-type="blog"
                   role="listitem"
                   style={`--item-index: ${index}`}
                   transition:name={`card-${post.id}`}>
            <a href={`/blog/${post.id}`} class="node-link">
              <div class="node-header">
                <span class="node-icon" aria-hidden="true">☕</span>
                <span class="mono-tag domain-tag">LOG | {post.data.author}</span>
              </div>
              <h4 class="node-title text-gradient">{post.data.title}</h4>
              <p class="node-impact">{post.data.description}</p>
              <div class="node-footer">
                <span class="execute-cmd">> read_memory_block()</span>
                <span class="line-decorator" aria-hidden="true"></span>
              </div>
            </a>
          </article>
        ))}

        {portfolioNodes.map((node, index) => (
          <article class:list={["repository-node", "glass-panel", `type-${node.category}`, "gs-node"]}
                   data-title={node.title}
                   data-desc={node.impact}
                   data-type="repo"
                   role="listitem"
                   style={`--item-index: ${index + posts.length}`}
                   transition:name={`repo-${index}`}>
            <a href={node.url} target="_blank" rel="noopener noreferrer" class="node-link" aria-label={`${node.title} - ${node.impact}`}>
              <div class="node-header">
                <span class="node-icon" aria-hidden="true">{getCategoryIcon(node.category)}</span>
                <span class="mono-tag domain-tag">REPO | {node.domain}</span>
              </div>
              <h4 class="node-title">{node.title}</h4>
              <p class="node-impact">{node.impact}</p>
              <div class="node-footer">
                <span class="execute-cmd">> git clone protocol</span>
                <span class="line-decorator" aria-hidden="true"></span>
              </div>
            </a>
          </article>
        ))}

      </div>

      <div id="noResults" class="hidden error-msg" role="alert" aria-live="polite">
        <p>Error 404: No se detectaron anomalías ni registros con esos parámetros.</p>
      </div>
    </section>

    <footer class="hub-footer glass-panel gs-reveal" role="contentinfo" transition:name="footer-section" transition:animate="fade">
      <h3 class="title-display">🌐 Connect & Scale</h3>
      <p class="text-secondary">Available for high-level architectural consulting and breaking barriers in open source.</p>

      <div class="social-grid" role="list" aria-label="Enlaces sociales">
        <a href="https://ko-fi.com/plantacerium" target="_blank" rel="noopener noreferrer" class="social-link" role="listitem">☕ Support via Ko-Fi</a>
        <a href="https://discord.gg/nbZqzwKXGS" target="_blank" rel="noopener noreferrer" class="social-link" role="listitem">💬 Neural Net (Discord)</a>
        <a href="https://plantacerium.github.io/" target="_blank" class="social-link" role="listitem">📡 Central Command Hub</a>
      </div>

      <div class="signature">
        Made with <span class="heart" aria-hidden="true">♥</span> and brain by <strong>Plantacerium</strong>
      </div>
    </footer>

  </main>
</Layout>

<script>
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    // Reinitialize GSAP animations after view transition
    gsap.fromTo(".gs-reveal",
      { y: 30, opacity: 0, filter: "blur(5px)" },
      { y: 0, opacity: 1, filter: "blur(0px)", duration: 0.8, stagger: 0.2, ease: "power2.out" }
    );

    const nodesToAnimate = Array.from(document.querySelectorAll('.gs-node'));
    gsap.fromTo(nodesToAnimate,
      { scale: 0.95, opacity: 0, y: 20 },
      { scale: 1, opacity: 1, y: 0, duration: 0.5, stagger: 0.03, delay: 0.3, ease: "back.out(1.2)" }
    );

    // Zen mode toggle
    const zenToggle = document.getElementById('zenToggle');
    zenToggle?.addEventListener('click', () => {
      document.body.classList.toggle('theme-zen');
      const isZen = document.body.classList.contains('theme-zen');
      const zenButton = zenToggle as HTMLButtonElement;
      
      zenButton.setAttribute('aria-pressed', String(isZen));

      if (isZen) {
        zenToggle.innerHTML = '⚡ Retornar a Alto Rendimiento';
        gsap.fromTo("body", {opacity: 0.8}, {opacity: 1, duration: 1, ease: "power2.inOut"});
      } else {
        zenToggle.innerHTML = '🧘‍♂️ Activar Modo Zen';
        gsap.fromTo("body", {opacity: 0.8}, {opacity: 1, duration: 0.5});
      }
    });
  });
</script>

<style>
  .max-width-expanded {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .hero-section {
    padding: 4rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-top: 1px solid var(--accent-main);
  }

  .architect-title {
    font-size: 4rem;
    letter-spacing: 2px;
    margin: 1rem 0 0.5rem;
    font-family: var(--font-display);
  }

  .architect-subtitle {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    letter-spacing: 4px;
    font-family: var(--font-mono);
  }

  .manifesto {
    max-width: 800px;
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .manifesto strong { color: var(--text-primary); }

  .toolchain-tags {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .action-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .omni-search-container {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .filter-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 600px;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .filter-tags { display: flex; gap: 1rem; }

  .btn-zen {
    background: transparent;
    border-color: var(--accent-warm);
    color: var(--accent-warm);
  }
  .btn-zen:hover {
    background: rgba(212, 163, 115, 0.1);
    box-shadow: 0 0 15px rgba(212, 163, 115, 0.3);
  }

  .node-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .repository-node {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--panel-border);
    transition: transform var(--transition-smooth), box-shadow var(--transition-smooth);
    min-height: 250px;
  }

  .node-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .type-blog:hover { border-color: var(--accent-secondary); box-shadow: 0 10px 30px rgba(139, 92, 246, 0.15); }
  .type-system:hover { border-color: var(--accent-main); box-shadow: 0 10px 30px rgba(0, 242, 255, 0.15); }
  .type-zen:hover { border-color: var(--accent-warm); box-shadow: 0 10px 30px rgba(212, 163, 115, 0.15); }
  .type-ui:hover { border-color: #f472b6; box-shadow: 0 10px 30px rgba(244, 114, 182, 0.15); }

  .repository-node:hover {
    transform: translateY(-4px);
    background: rgba(30, 30, 35, 0.9);
  }

  .node-header { margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .node-title { font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 0.5rem; line-height: 1.3; }
  .node-impact { font-size: 0.9rem; color: var(--text-secondary); flex-grow: 1; line-height: 1.5; }
  .node-footer { margin-top: 1.5rem; display: flex; align-items: center; gap: 1rem; opacity: 0.7; }
  .execute-cmd { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent-main); }
  .line-decorator { flex-grow: 1; height: 1px; background: linear-gradient(90deg, var(--accent-main), transparent); }

  .hidden { display: none; }
  .error-msg { text-align: center; padding: 4rem; color: var(--accent-warm); font-family: var(--font-mono); }

  .hub-footer {
    padding: 3rem;
    text-align: center;
    border-bottom: 1px solid var(--accent-secondary);
  }

  .social-grid {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
    margin: 2rem 0;
  }

  .social-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-primary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--border-radius-sm);
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    border-color: var(--accent-warm);
    color: var(--accent-warm);
    background: rgba(212, 163, 115, 0.05);
  }

  .signature {
    margin-top: 3rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .heart {
    color: #ef4444;
    animation: heartbeat 1.5s infinite;
    display: inline-block;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    15% { transform: scale(1.3); }
    30% { transform: scale(1); }
    45% { transform: scale(1.3); }
    60% { transform: scale(1); }
  }

  @media (max-width: 1400px) { .node-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 1024px) { .node-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .architect-title { font-size: 2.5rem; }
    .filter-controls { flex-direction: column; justify-content: center; }
  }
  @media (max-width: 600px) { .node-grid { grid-template-columns: 1fr; } }
</style>
