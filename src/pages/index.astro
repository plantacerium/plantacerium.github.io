  { title: "La Colisión de los Tres Ángulos", url: "https://github.com/plantacerium/La-Colision-de-los-Tres-Angulos", domain: "Meditación", impact: "Una epopeya de autodescubrimiento, geometría del alma y evolución espiritual.", category: "zen" },
  { title: "Anima Essentia", url: "https://github.com/plantacerium/Anima-Essentia", domain: "Animales / Consciencias", impact: "Software para protectoras de animales para crear fichas de perfiles cognitivos y espirituales.", category: "zen" },
  { title: "Stelar Nexus Records", url: "https://github.com/plantacerium/The-Stelar-Nexus-Records", domain: "Museum Art Gallery", impact: "High fidelity, immersive 3D web, transforms GitHub data into interactive DNA double helixes.", category: "ui" },
  { title: "Organic Craft Markers", url: "https://github.com/plantacerium/Organic-Craft-Markers", domain: "Inmmersive Web Experiences", impact: "High tier, interactive image marker and data visualization tool.", category: "ui" },
  { title: "The Mandala Weaver", url: "https://github.com/plantacerium/The-Mandala-Weaver", domain: "Emmanation Outer Inner Writing", impact: "Fundamental shift in the architecture of writing human expression.", category: "zen" },
  { title: "plantacerium.github.io", url: "https://plantacerium.github.io/", domain: "Deep Writing", impact: "The central command hub. Technical portfolio.", category: "ui" },
  { title: "GoLuminamics", url: "https://github.com/plantacerium/GoLuminamics", domain: "Game & Computation", impact: "Strategic Board Game Where Light Becomes Your Path To Victory.", category: "ui" },
  { title: "GeoLuminamics", url: "https://github.com/plantacerium/GeoLuminamics", domain: "Creative Geometry Light Engine", impact: "Space where logic dissolves into luminosity, inviting the creator into a state of flow.", category: "ui" },
  { title: "Silice Protocol", url: "https://github.com/plantacerium/SiliceProtocol", domain: "AI Infrastructure & Standards", impact: "Low level protocol designed for high efficiency AI agentic developments.", category: "system" },
  { title: "Cogni Trace", url: "https://github.com/plantacerium/CogniTrace", domain: "Debug & Intelligence", impact: "Observability tool that transforms runtime data into actionable system AI intelligence.", category: "system" },
  { title: "Greenmerald", url: "https://github.com/plantacerium/greenmerald-tui-markdown-renderer", domain: "Developer Experience TUI", impact: "Bringing elegance to the terminal. A high-performance file explorer and renderer.", category: "system" },
  { title: "Greenmerald Notes", url: "https://github.com/plantacerium/GreenmeraldNotes", domain: "Knowledge Base Interactive", impact: "Bringing elegance to the terminal. A high-performance notes reader and interactive experience.", category: "system" },
  { title: "Code Lumer & Lens Assembler", url: "https://github.com/plantacerium/CodeLumer", domain: "App & Tooling", impact: "Illuminating code with high resolutions code snapshots and experience the dual camera.", category: "ui" },
  { title: "Quantum Chronometer", url: "https://github.com/plantacerium/QuantumChronometerEmojinator", domain: "Precision & UI Experimentation", impact: "A showcase of quantum state management and creative UI interactions.", category: "ui" },
  { title: "Powerer Pointerer Silice", url: "https://github.com/plantacerium/PowererPointererSIlice", domain: "Automation Codebase Demos", impact: "Your Codebase, Narrated by AI, Rendered in a Beautiful Slide Presentation.", category: "ui" },
  { title: "Cyber Walk Zola Theme", url: "https://github.com/plantacerium/zola-theme-cyber-walk", domain: "Blog Terminal Theme", impact: "Digital workspace designed for those who communicate through code.", category: "ui" },
  { title: "Power Matrix Rain", url: "https://github.com/plantacerium/PowerMatrixRain", domain: "Program Your Reality", impact: "Programmable visualization engine. Built with the raw power of Rust and WGPU.", category: "system" },
  { title: "Chronos Aeternum", url: "https://github.com/plantacerium/ChronosAeternum", domain: "Sacred Horological Instrument", impact: "Meditative interface for anchoring your consciousness in the void.", category: "zen" },
  { title: "Chronos Aeternum Zen", url: "https://github.com/plantacerium/ChronosAeternumZen", domain: "The Meditative Brush of Time", impact: "Digital Zen Sanctuary where time is a descending spiral of depth and presence.", category: "zen" },
  { title: "Chronos Aeternum TUI", url: "https://github.com/plantacerium/ChronosAeternumTUI", domain: "The Meditative Breath of Time", impact: "Transforms the ephemeral passage of time into a permanent inventory of human experience.", category: "zen" },
