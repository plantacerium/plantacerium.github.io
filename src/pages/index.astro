---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

// 1. OBTENCIÓN DE DATOS: Bitácoras (Blogs)
const posts = (await getCollection('blog')).sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf()
);


// 2. OBTENCIÓN DE DATOS: Matriz Completa de Repositorios (ADN Técnico)
const portfolioNodes = [
